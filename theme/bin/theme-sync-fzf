#!/usr/bin/env bash
# Apply the active catppuccin flavor to fzf by writing the opts cache file.
# Shells and tmux popups read it via FZF_DEFAULT_OPTS_FILE (set once to this
# constant path), so they pick up the new palette on their next launch without
# any per-process environment push.
set -euo pipefail

bin_dir="$(cd "$(dirname "$0")" && pwd)"
want="$("$bin_dir/theme-fzf-opts")"

cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/dotfiles"
cache="$cache_dir/fzf-default-opts"

mkdir -p "$cache_dir"
if [[ ! -f "$cache" ]] || [[ "$(<"$cache")" != "$want" ]]; then
  tmp="$cache.tmp.$$"
  printf '%s\n' "$want" > "$tmp"
  mv "$tmp" "$cache"
fi
