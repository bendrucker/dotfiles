#!/usr/bin/env bash
# Summarize tmux usage patterns from the hook-based usage log.
#
# Usage: tmux-usage-report [days]
#   days  — look back this many days (default: 30)
#
# Reads $XDG_DATA_HOME/tmux/usage.jsonl (newline-delimited JSON)

set -euo pipefail

log_file="${XDG_DATA_HOME:-$HOME/.local/share}/tmux/usage.jsonl"

if [[ ! -f "$log_file" ]]; then
  echo "No usage log found at $log_file"
  echo "Hooks will start recording once tmux loads the updated config."
  exit 0
fi

days="${1:-30}"

if date -v-1d +%s &>/dev/null; then
  cutoff=$(date -u -v-"${days}d" +%Y-%m-%dT%H:%M:%SZ)
else
  cutoff=$(date -u -d "$days days ago" +%Y-%m-%dT%H:%M:%SZ)
fi

recent=$(jq -c --arg cutoff "$cutoff" 'select(.ts >= $cutoff)' "$log_file")

if [[ -z "$recent" ]]; then
  echo "No events in the last $days days."
  exit 0
fi

count() { echo "$recent" | jq -c --arg e "$1" 'select(.event == $e)' | wc -l | tr -d ' '; }

total=$(echo "$recent" | wc -l | tr -d ' ')
first=$(echo "$recent" | head -1 | jq -r .ts)
last=$(echo "$recent" | tail -1 | jq -r .ts)

gum format --type markdown <<EOF
# tmux usage report (last $days days)
- **Period:** $first to $last
- **Total events:** $total
EOF
echo

{ echo "Event,Count"
  echo "$recent" | jq -r .event | sort | uniq -c | sort -rn | \
    awk '{ printf "%s,%s\n", $2, $1 }'
} | gum table --print
echo

sessions=$(count session-created)
new_windows=$(count window-created)
splits=$(count pane-created)
copies=$(count copy-mode)
layouts=$(count layout-changed)
zooms=$(count pane-zoom)
renames=$(count window-renamed)

echo "--- Sessions created: $sessions"
echo "--- Windows created: $new_windows"
echo "--- Pane splits: $splits"
echo "--- Copy mode entries: $copies"
echo "--- Layout changes: $layouts"
echo "--- Zoom toggles: $zooms"
echo "--- Window renames: $renames"
echo

echo "--- Hourly distribution (UTC) ---"
echo "$recent" | jq -r '.ts | split("T")[1][:2]' | sort | uniq -c | sort -k2n
