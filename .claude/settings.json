{
  "permissions": {
    "allow": [
      "WebFetch(domain:mise.jdx.dev)",
      "WebFetch(domain:docs.brew.sh)",
      "Skill(tmux:tmux)",
      "Bash(tmux source-file:*)",
      "Bash(tmux list-keys:*)",
      "Bash(tmux show-options:*)",
      "Bash(tmux show-messages:*)",
      "Bash(tmux show-environment:*)",
      "Bash(tmux unbind:*)"
    ],
    "deny": []
  },
  "enabledPlugins": {
    "tmux@bendrucker": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-post-tool-use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-stop"
          }
        ]
      }
    ]
  }
}
