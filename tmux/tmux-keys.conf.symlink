# Splits inherit the current pane's working directory
bind '"' split-window -v -c "#{pane_current_path}"
bind % split-window -h -c "#{pane_current_path}"

# Session switcher (sesh + fzf)
bind t display-popup -E tmux-sessions

# Window switcher (fzf)
bind w display-popup -E tmux-windows

# Jump to window with bell alert
bind b run-shell -b tmux-bell-jump
