#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/_fzf-colors"

session=${1:-$(tmux display-message -p '#{session_name}')}
format="#{session_name}:#{window_index} #{window_name} [#{pane_current_command}]"

target=$(tmux list-windows -t "$session" -F "$format" \
  | fzf --no-sort --border --prompt "window ($session)> " --color="$colors" \
    --tmux center,60%,60% \
    --header 'ctrl-x: kill' \
    --preview "tmux capture-pane -t {1} -p | tail -n \"\$FZF_PREVIEW_LINES\"" \
    --bind "ctrl-x:execute-silent(tmux kill-window -t {1})+reload(tmux list-windows -t $session -F '$format')") || true

[[ -n "$target" ]] && tmux switch-client -t "$(echo "$target" | awk '{print $1}')"
