#!/usr/bin/env bash
# Present an fzf picker of tools and exec the selection in the current shell.
# Intended to be invoked from a tmux display-popup so the popup's TTY becomes
# the tool's TTY. Add a new tool by appending a line — the visible text IS the
# command that runs on selection.

set -euo pipefail

cmd=$(fzf --prompt '⚡ ' --no-sort --height 100% --border=rounded --border-label ' launch ' <<'TOOLS'
lazygit
gh dash
TOOLS
)

# shellcheck disable=SC2086  # word-splitting is intentional so "gh dash" runs as two words
[[ -n "$cmd" ]] && exec $cmd
