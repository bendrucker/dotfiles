#!/usr/bin/env bash
# Compare the OS appearance against the active catppuccin flavor.
# Exit 0 (success) when they differ — the caller should re-sync.
# Exit 1 (failure) when they match — no action needed.
set -euo pipefail

[[ "$(uname -s)" == "Darwin" ]] || exit 1

if [[ "$(defaults read -g AppleInterfaceStyle 2>/dev/null)" == "Dark" ]]; then
  want="mocha"
else
  want="latte"
fi

current=$(tmux show -gv @catppuccin_flavor 2>/dev/null || echo "")
[[ "$current" != "$want" ]]
