#!/usr/bin/env bash
set -euo pipefail

self_dir=$(dirname "$0")
source "$self_dir/_fzf-colors"

target=$("$self_dir/_tmux-session-list" \
  | fzf --no-sort --border --prompt 'session> ' --color="$colors" \
    --tmux center,60%,60% \
    --header 'ctrl-x: kill' \
    --bind 'focus:transform-header([[ {} == *\(* ]] && echo "ctrl-x: kill · tab: windows" || echo "ctrl-x: kill")' \
    --preview 'tmux capture-pane -t {1} -p 2>/dev/null || sesh preview {}' \
    --bind "tab:transform([[ {1} == *:* || {} == *\(* ]] && echo become\\($self_dir/tmux-windows\\ {1}\\))" \
    --bind "ctrl-x:execute-silent(tmux kill-session -t {1})+reload($self_dir/_tmux-session-list)") || true

if [[ -n "$target" ]]; then
  key=$(echo "$target" | awk '{print $1}')
  if tmux has-session -t "$key" 2>/dev/null; then
    tmux switch-client -t "$key"
  else
    sesh connect "$key"
  fi
fi
