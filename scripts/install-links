#!/usr/bin/env sh
# Install declarative symlinks from links.conf
# Usage: install-links [dotfiles-root]
set -e

DOTFILES_ROOT="${1:-$(cd "$(dirname "$0")/.." && pwd -P)}"
CONF="$(dirname "$0")/../links.conf"

while IFS=: read -r src dst; do
  case "$src" in "#"*|"") continue ;; esac
  dst=$(echo "$dst" | sed "s|^~|$HOME|")
  mkdir -p "$(dirname "$dst")"
  ln -sf "$DOTFILES_ROOT/$src" "$dst"
done < "$CONF"
