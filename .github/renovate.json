{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["neovim/config/init\\.lua$"],
      "matchStrings": [
        "\"(?<depName>[^\"]+/[^\"]+)\"[,\\s]*tag\\s*=\\s*\"(?<currentValue>v[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    },
    {
      "matchManagers": ["mise"],
      "minimumReleaseAge": "2 weeks"
    }
  ]
}
